# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bodymanual

# WHOOP developer app (register the redirect URI {BASE_URL}/auth/whoop/callback)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-mini

# App
# If you authorize WHOOP from your phone, this must be a tunnel URL (ngrok/cloudflared),
# not localhost — see README.
BASE_URL=http://localhost:8000
SECRET_KEY=generate-a-long-random-string
DEFAULT_TIMEZONE=America/New_York
DAILY_PULL_HOUR=6
