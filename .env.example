# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bodymanual

# WHOOP developer app (register the redirect URI {BASE_URL}/auth/whoop/callback)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Withings developer app (register the redirect URI {BASE_URL}/auth/withings/callback)
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=
# Global model used by every AI route unless a route-specific override below is set.
OPENAI_MODEL=gpt-4o-mini
# Per-route model overrides (all OPTIONAL). Leave unset to use OPENAI_MODEL for
# that route — i.e. current behavior. Set one to give a specific task tier its
# own model. See app/services/model_router.py for what each route covers.
#   fast          — cheap classification (log-vs-question, intent, yes/no)
#   extract       — structured JSON extraction (events, user facts, future memory)
#   coach         — user-facing prose (/today, Q&A, /focus)
#   deep          — higher-value synthesis (weekly summary, future rules/manual)
#   quality_gate  — cheap response validation (future anti-generic advice check)
# OPENAI_MODEL_FAST=
# OPENAI_MODEL_EXTRACT=
# OPENAI_MODEL_COACH=
# OPENAI_MODEL_DEEP=
# OPENAI_MODEL_QUALITY_GATE=

# App
# If you authorize WHOOP from your phone, this must be a tunnel URL (ngrok/cloudflared),
# not localhost — see README.
BASE_URL=http://localhost:8000
SECRET_KEY=generate-a-long-random-string
DEFAULT_TIMEZONE=America/New_York
DAILY_PULL_HOUR=6

# Wake-aware morning message (local times). The job polls WHOOP across this
# window and sends once your main sleep has ended and recovery/sleep is usable;
# at the cutoff it sends a degraded fallback. Defaults shown.
MORNING_WATCH_START_LOCAL=05:00
MORNING_WATCH_CUTOFF_LOCAL=10:30
MORNING_WATCH_INTERVAL_MINUTES=30
